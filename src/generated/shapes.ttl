@prefix core: <https://w3id.org/jeswr/core#>.
@prefix dcterms: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix media: <https://w3id.org/jeswr/sectors/media#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix shapes: <https://w3id.org/jeswr/sectors/media/shapes#>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

shapes:Album-title sh:datatype xsd:string;
    sh:maxCount 1;
    sh:minCount 1;
    sh:path dcterms:title;
    sh:severity sh:Warning.
shapes:AlbumShape a sh:NodeShape;
    sh:property shapes:Album-title;
    sh:targetClass media:Album.
shapes:Artist-name sh:datatype xsd:string;
    sh:maxCount 1;
    sh:path foaf:name;
    sh:severity sh:Info.
shapes:ArtistShape a sh:NodeShape;
    sh:property shapes:Artist-name;
    sh:targetClass media:Artist.
shapes:Instant-inXSDDateTime sh:datatype xsd:dateTime;
    sh:maxCount 1;
    sh:minCount 1;
    sh:path time:inXSDDateTime;
    sh:severity sh:Violation.
shapes:PlaybackEvent-atTime sh:class time:Instant;
    sh:maxCount 1;
    sh:minCount 1;
    sh:nodeKind sh:IRI;
    sh:path core:atTime;
    sh:severity sh:Violation.
shapes:PlaybackEvent-completionFraction sh:datatype xsd:decimal;
    sh:maxCount 1;
    sh:maxInclusive 1;
    sh:minInclusive 0;
    sh:path media:completionFraction;
    sh:severity sh:Info.
shapes:PlaybackEvent-hadParticipant sh:class core:Agent;
    sh:minCount 1;
    sh:nodeKind sh:IRI;
    sh:path core:hadParticipant;
    sh:severity sh:Warning.
shapes:PlaybackEvent-loved sh:datatype xsd:boolean;
    sh:maxCount 1;
    sh:path media:loved;
    sh:severity sh:Info.
shapes:PlaybackEvent-msPlayed sh:datatype xsd:integer;
    sh:maxCount 1;
    sh:minInclusive 0;
    sh:path media:msPlayed;
    sh:severity sh:Info.
shapes:PlaybackEvent-onAccount sh:class media:MediaAccount;
    sh:maxCount 1;
    sh:path media:onAccount;
    sh:severity sh:Warning.
shapes:PlaybackEvent-playedVia sh:nodeKind sh:BlankNodeOrIRI;
    sh:path media:playedVia;
    sh:severity sh:Info.
shapes:PlaybackEvent-playedWork sh:class media:CreativeWork;
    sh:maxCount 1;
    sh:minCount 1;
    sh:nodeKind sh:IRI;
    sh:path media:playedWork;
    sh:severity sh:Violation.
shapes:PlaybackEventShape a sh:NodeShape;
    sh:property shapes:PlaybackEvent-atTime, shapes:PlaybackEvent-completionFraction, shapes:PlaybackEvent-hadParticipant, shapes:PlaybackEvent-loved, shapes:PlaybackEvent-msPlayed, shapes:PlaybackEvent-onAccount, shapes:PlaybackEvent-playedVia, shapes:PlaybackEvent-playedWork;
    sh:targetClass media:PlaybackEvent.
shapes:PlayedAtInstantShape a sh:NodeShape;
    sh:property shapes:Instant-inXSDDateTime;
    sh:targetClass time:Instant.
shapes:Track-durationSeconds sh:datatype xsd:decimal;
    sh:maxCount 1;
    sh:minInclusive 0;
    sh:path media:durationSeconds;
    sh:severity sh:Info.
shapes:Track-inAlbum sh:class media:Album;
    sh:maxCount 1;
    sh:nodeKind sh:IRI;
    sh:path media:inAlbum;
    sh:severity sh:Info.
shapes:Track-isrc sh:datatype xsd:string;
    sh:maxCount 1;
    sh:path media:isrc;
    sh:pattern "^[A-Z]{2}[A-Z0-9]{3}[0-9]{2}[0-9]{5}$";
    sh:severity sh:Warning.
shapes:Track-performedByArtist sh:class media:Artist;
    sh:maxCount 1;
    sh:nodeKind sh:IRI;
    sh:path media:performedByArtist;
    sh:severity sh:Info.
shapes:Track-title sh:datatype xsd:string;
    sh:maxCount 1;
    sh:minCount 1;
    sh:minLength 1;
    sh:path dcterms:title;
    sh:pattern "\\S";
    sh:severity sh:Violation.
shapes:TrackShape a sh:NodeShape;
    sh:property shapes:Track-durationSeconds, shapes:Track-inAlbum, shapes:Track-isrc, shapes:Track-performedByArtist, shapes:Track-title;
    sh:targetClass media:Track.
