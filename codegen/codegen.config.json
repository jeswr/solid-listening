{
  "shapesBase": "https://w3id.org/jeswr/sectors/media/shapes#",
  "prefixes": {
    "media": "https://w3id.org/jeswr/sectors/media#",
    "core": "https://w3id.org/jeswr/core#",
    "time": "http://www.w3.org/2006/time#",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "dcterms": "http://purl.org/dc/terms/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "entities": [
    {
      "name": "Scrobble",
      "kind": "composite",
      "root": "event",
      "nodes": {
        "event": {
          "targetClass": "https://w3id.org/jeswr/sectors/media#PlaybackEvent",
          "fragment": "it",
          "fields": { "msPlayed": {} },
          "links": { "playedWork": "track", "atTime": "playedAt" }
        },
        "track": {
          "targetClass": "https://w3id.org/jeswr/sectors/media#Track",
          "fragment": "track",
          "fields": {
            "title": { "rename": "trackTitle" },
            "durationSeconds": {},
            "isrc": {}
          },
          "links": { "performedByArtist": "artist", "inAlbum": "album" }
        },
        "playedAt": {
          "targetClass": "http://www.w3.org/2006/time#Instant",
          "fragment": "playedAt",
          "fields": { "inXSDDateTime": { "rename": "playedAt" } }
        },
        "artist": {
          "targetClass": "https://w3id.org/jeswr/sectors/media#Artist",
          "fragment": "artist",
          "fields": { "name": { "rename": "artistName" } }
        },
        "album": {
          "targetClass": "https://w3id.org/jeswr/sectors/media#Album",
          "fragment": "album",
          "fields": { "title": { "rename": "albumTitle" } }
        }
      }
    }
  ]
}
